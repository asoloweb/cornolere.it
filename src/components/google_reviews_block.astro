---
interface GoogleReview {
	author_name?: string;
	author_url?: string;
	profile_photo_url?: string;
	rating?: number;
	text?: string;
	relative_time_description?: string;
	time?: number;
}

type ReviewCard = GoogleReview;

interface GooglePlaceDetails {
	name?: string;
	rating?: number;
	user_ratings_total?: number;
	reviews?: GoogleReview[];
	url?: string;
}

interface PlaceIdCacheEntry {
	placeId: string;
	expiresAt: number;
}

interface ReviewsCacheEntry {
	placeDetails: GooglePlaceDetails;
	reviews: GoogleReview[];
	expiresAt: number;
}

interface Props {
	titolo?: string;
	sottotitolo?: string;
	google_place_id?: string;
	google_business_query?: string;
	numero_recensioni?: number;
	cta_label?: string;
	cta_href?: string;
}

const {
	titolo = 'Recensioni Google',
	sottotitolo = '',
	google_place_id = '',
	google_business_query = 'Studio Legale Portantiolo & Partners',
	numero_recensioni = 6,
	cta_label = 'Vedi tutte su Google',
	cta_href = '',
} = Astro.props;

const apiKey = import.meta.env.GOOGLE_MAPS_API_KEY || import.meta.env.GOOGLE_PLACES_API_KEY;
const maxReviews = Math.min(10, Math.max(1, Number(numero_recensioni) || 6));
const placeQuery = String(
	google_business_query || import.meta.env.GOOGLE_BUSINESS_QUERY || 'Studio Legale Portantiolo & Partners'
).trim();
const CACHE_TTL_MS = 7 * 24 * 60 * 60 * 1000;

const cacheStoreKey = '__googleReviewsCacheStore__';
const cacheStore =
	((globalThis as any)[cacheStoreKey] as
		| {
				placeIdByQuery: Map<string, PlaceIdCacheEntry>;
				reviewsByPlaceId: Map<string, ReviewsCacheEntry>;
		  }
		| undefined) ||
	(() => {
		const store = {
			placeIdByQuery: new Map<string, PlaceIdCacheEntry>(),
			reviewsByPlaceId: new Map<string, ReviewsCacheEntry>(),
		};
		(globalThis as any)[cacheStoreKey] = store;
		return store;
	})();

let placeId = String(google_place_id || import.meta.env.GOOGLE_MYBUSINESS_PLACE_ID || '').trim();
let placeDetails: GooglePlaceDetails | null = null;
let reviews: GoogleReview[] = [];
const fallbackReviews: ReviewCard[] = [
	{
		author_name: 'Cliente verificato',
		rating: 5,
		text: 'Professionalita, chiarezza e supporto costante durante tutta la pratica.',
		relative_time_description: 'Recensione recente',
	},
	{
		author_name: 'Cliente verificato',
		rating: 5,
		text: 'Team competente e disponibile. Ho ricevuto risposte rapide e precise.',
		relative_time_description: 'Recensione recente',
	},
	{
		author_name: 'Cliente verificato',
		rating: 5,
		text: 'Esperienza positiva: approccio concreto e massima attenzione ai dettagli.',
		relative_time_description: 'Recensione recente',
	},
];

async function fetchJson(url: string) {
	const response = await fetch(url, {
		headers: {
			Accept: 'application/json',
		},
	});

	if (!response.ok) {
		throw new Error(`Google API ${response.status}`);
	}

	return response.json();
}

async function resolvePlaceId(input: string) {
	if (!apiKey || !input) return '';
	const normalized = input.trim().toLowerCase();
	const cached = cacheStore.placeIdByQuery.get(normalized);
	if (cached && cached.expiresAt > Date.now()) {
		return cached.placeId;
	}
	const url = new URL('https://maps.googleapis.com/maps/api/place/findplacefromtext/json');
	url.searchParams.set('input', input);
	url.searchParams.set('inputtype', 'textquery');
	url.searchParams.set('fields', 'place_id');
	url.searchParams.set('language', 'it');
	url.searchParams.set('key', apiKey);

	const data = await fetchJson(url.toString());
	if (data?.status !== 'OK') return '';
	const foundPlaceId = data?.candidates?.[0]?.place_id || '';
	if (foundPlaceId) {
		cacheStore.placeIdByQuery.set(normalized, {
			placeId: foundPlaceId,
			expiresAt: Date.now() + CACHE_TTL_MS,
		});
	}
	return foundPlaceId;
}

async function fetchPlaceDetails(inputPlaceId: string) {
	if (!apiKey || !inputPlaceId) return null;
	const url = new URL('https://maps.googleapis.com/maps/api/place/details/json');
	url.searchParams.set('place_id', inputPlaceId);
	url.searchParams.set('fields', 'name,rating,user_ratings_total,reviews,url');
	url.searchParams.set('reviews_sort', 'newest');
	url.searchParams.set('language', 'it');
	url.searchParams.set('key', apiKey);

	const data = await fetchJson(url.toString());
	if (data?.status !== 'OK' || !data?.result) return null;
	return data.result as GooglePlaceDetails;
}

if (apiKey) {
	try {
		if (!placeId && placeQuery) {
			placeId = await resolvePlaceId(placeQuery);
		}
		if (placeId) {
			const cachedReviews = cacheStore.reviewsByPlaceId.get(placeId);
			if (cachedReviews && cachedReviews.expiresAt > Date.now()) {
				placeDetails = cachedReviews.placeDetails;
				reviews = cachedReviews.reviews.slice(0, maxReviews);
			} else {
				placeDetails = await fetchPlaceDetails(placeId);
				const sortedReviews = Array.isArray(placeDetails?.reviews)
					? [...placeDetails.reviews].sort((a, b) => (b.time || 0) - (a.time || 0))
					: [];
				reviews = sortedReviews.slice(0, maxReviews);
				if (placeDetails) {
					cacheStore.reviewsByPlaceId.set(placeId, {
						placeDetails,
						reviews: sortedReviews,
						expiresAt: Date.now() + CACHE_TTL_MS,
					});
				}
			}
		}
	} catch (error) {
		console.error('Errore nel caricamento recensioni Google:', error);
	}
}

const sliderId = `google-reviews-slider-${Math.random().toString(36).slice(2)}`;
const placeName = placeDetails?.name || placeQuery;
const rating = placeDetails?.rating;
const totalReviews = placeDetails?.user_ratings_total;
const profileUrl = cta_href || placeDetails?.url || '';
const ratingStars = rating ? `${'★'.repeat(Math.round(rating))}${'☆'.repeat(5 - Math.round(rating))}` : '';
const cardsToRender: ReviewCard[] = reviews.length > 0 ? reviews : fallbackReviews;
const isFallbackMode = reviews.length === 0;
const hasMultipleSlides = cardsToRender.length > 1;
const googleIconSrc = 'https://cdn.trustindex.io/assets/platform/Google/icon.svg';
const googleStarSrc = 'https://cdn.trustindex.io/assets/platform/Google/star/f.svg';

function reviewStars(value: number | undefined) {
	const rounded = Math.min(5, Math.max(0, Math.round(Number(value) || 0)));
	return `${'★'.repeat(rounded)}${'☆'.repeat(5 - rounded)}`;
}

function avatarSrc(value: string | undefined) {
	if (!value) return '';
	return `/api/google-avatar?u=${encodeURIComponent(value)}`;
}

function formatFullDate(value: number | undefined) {
	if (!value) return '';
	try {
		return new Intl.DateTimeFormat('it-IT', { dateStyle: 'long', timeStyle: 'short' }).format(
			new Date(value * 1000)
		);
	} catch {
		return '';
	}
}
---

<section class="google_reviews_block" data-aos="fade-up" data-aos-duration="1500">
		<div class="google_reviews_inner">
			<div class="google_reviews_header">
				<div>
					{titolo && <h2 class="google_reviews_title">{titolo}</h2>}
					{sottotitolo && <p class="google_reviews_subtitle">{sottotitolo}</p>}
					{isFallbackMode && (
						<p class="google_reviews_notice">
							Anteprima recensioni. Configura Google Places API per caricare quelle reali.
						</p>
					)}
				</div>
				<div class="google_reviews_summary">
					<p class="google_reviews_place">{placeName}</p>
					{rating && (
						<p class="google_reviews_rating">
							<span>{rating.toFixed(1)}</span>
							<span aria-hidden="true">{ratingStars}</span>
							{totalReviews && <span>({totalReviews} recensioni)</span>}
						</p>
					)}
					{profileUrl && (
						<a class="google_reviews_link" href={profileUrl} target="_blank" rel="noopener noreferrer">
							{cta_label}
						</a>
					)}
				</div>
			</div>

			<div
				class="google_reviews_slider slider_block swiper"
				id={sliderId}
				data-swiper-enabled={hasMultipleSlides ? 'true' : 'false'}
			>
				<div class="swiper-wrapper">
					{cardsToRender.map((review) => (
						<article class="swiper-slide single_slide google_review_slide">
							<div class="ti-inner">
								<div class="ti-review-header">
									<div class="ti-platform-icon" title="Pubblicato su Google">
										<img src={googleIconSrc} alt="Google" width="20" height="20" loading="lazy" />
									</div>
									<div class={`ti-profile-img ${review.profile_photo_url ? '' : 'is-fallback'}`}>
										{review.profile_photo_url ? (
											<img
												class="google_review_avatar"
												src={avatarSrc(review.profile_photo_url)}
												alt={`${review.author_name || 'Utente Google'} profile picture`}
												referrerpolicy="no-referrer"
												decoding="async"
												loading="lazy"
												onerror="this.parentElement?.setAttribute('data-avatar-fallback','true')"
											/>
										) : null}
										<div class="ti-avatar-fallback" aria-hidden="true">
											{(review.author_name || 'U').slice(0, 1).toUpperCase()}
										</div>
									</div>
									<div class="ti-profile-details">
										<div class="ti-name">{review.author_name || 'Utente Google'}</div>
										<div class="ti-date">
											<span title={formatFullDate(review.time)}>
												{review.relative_time_description || 'Recensione recente'}
											</span>
										</div>
									</div>
								</div>
								<span
									class="ti-stars"
									aria-label={`Valutazione ${review.rating || 0} su 5`}
									title={reviewStars(review.rating)}
								>
									{Array.from({ length: 5 }).map((_, index) => (
										<img
											class={`ti-star ${(review.rating || 0) < index + 1 ? 'is-empty' : ''}`}
											src={googleStarSrc}
											alt="Google"
											width="17"
											height="17"
											loading="lazy"
										/>
									))}
								</span>
								<div class="ti-review-text-container ti-review-content">
									{review.text?.trim() || 'Recensione senza commento testuale.'}
								</div>
							</div>
						</article>
					))}
				</div>
				{hasMultipleSlides && <div class="swiper-pagination"></div>}
			</div>
		</div>
	</section>

<style>
	.google_reviews_block {
		margin: 40px 0;
	}

	.google_reviews_inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 30px;
		border-radius: 20px;
		background: #fff;
	}

	.google_reviews_header {
		display: flex;
		justify-content: space-between;
		gap: 16px;
		margin-bottom: 20px;
		align-items: flex-start;
		flex-wrap: wrap;
	}

	.google_reviews_title {
		margin: 0;
		font-size: 60px;
		line-height: 1.1;
	}

	.google_reviews_subtitle {
		margin: 8px 0 0;
		font-size: 18px;
		line-height: 1.5;
	}

	.google_reviews_notice {
		margin: 8px 0 0;
		font-size: 14px;
		opacity: 0.75;
	}

	.google_reviews_place {
		margin: 0;
		font-weight: 700;
	}

	.google_reviews_rating {
		margin: 6px 0 0;
		display: flex;
		gap: 8px;
		align-items: center;
	}

	.google_reviews_link {
		display: inline-block;
		margin-top: 10px;
		font-weight: 700;
		text-decoration: underline;
		color:var(--primary);
	}

	.google_reviews_slider {
		height: auto;
		margin: 0;
	}

	.google_review_slide {
		text-align: left;
		background: var(--bianco);
		border: 1px solid #e8e8e8;
		border-radius: 16px;
		padding: 20px;
		min-height: 280px;
		justify-content: flex-start;
	}

	.google_review_top {
		display: flex;
		gap: 12px;
		align-items: center;
	}

	.ti-inner {
		width: 100%;
	}

	.ti-review-header {
		display: grid;
		grid-template-columns: 20px 48px 1fr;
		gap: 10px;
		align-items: center;
	}

	.ti-profile-img {
		width: 48px;
		height: 48px;
		position: relative;
	}

	.ti-profile-details {
		min-width: 0;
	}

	.ti-name {
		font-weight: 700;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.ti-date {
		font-size: 14px;
		opacity: 0.75;
		margin-top: 2px;
	}

	.ti-stars {
		display: inline-flex;
		gap: 2px;
		margin-top: 10px;
	}

	.ti-star.is-empty {
		opacity: 0.22;
	}

	.ti-review-text-container {
		margin-top: 12px;
		line-height: 1.6;
	}

	.google_review_avatar {
		width: 48px;
		height: 48px;
		border-radius: 999px;
		object-fit: cover;
		display: block;
	}

	.google_review_author {
		margin: 0;
		font-weight: 700;
	}

	.ti-avatar-fallback {
		width: 48px;
		height: 48px;
		border-radius: 999px;
		display: none;
		place-items: center;
		font-weight: 700;
		background: #f0f0f0;
	}

	.ti-profile-img[data-avatar-fallback='true'] .google_review_avatar,
	.ti-profile-img.is-fallback .google_review_avatar {
		display: none;
	}

	.ti-profile-img[data-avatar-fallback='true'] .ti-avatar-fallback,
	.ti-profile-img.is-fallback .ti-avatar-fallback {
		display: grid;
	}

	.google_review_stars {
		margin: 4px 0 0;
	}

	.google_review_text {
		margin: 14px 0 0;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 7;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.google_review_time {
		margin: 12px 0 0;
		font-size: 14px;
		opacity: 0.75;
	}

	@media (max-width: 768px) {
		.google_reviews_inner {
			padding: 20px;
		}

		.google_reviews_title {
			font-size: 30px;
		}
	}
</style>
