---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { DIRECTUS_URL, directusItemsUrl } from '../lib/directus';
import '../styles/global.css';

export interface Props {
	title: string;
	seoTitle?: string;
	seoDescription?: string;
}

const { title, seoTitle, seoDescription } = Astro.props;
const resolvedTitle = seoTitle || title;
const shouldLoadThirdPartyScripts = !import.meta.env.DEV;
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://controllocartellesattoriali.it').replace(/\/+$/, '');
const organizationName =
	import.meta.env.PUBLIC_ORGANIZATION_NAME || 'Controllo Cartelle Esattoriali';
const organizationEmail =
	import.meta.env.PUBLIC_ORGANIZATION_EMAIL || 'info@controllocartellesattoriali.it';
const organizationPhone =
	import.meta.env.PUBLIC_ORGANIZATION_PHONE || '+39 0423 223322';
const organizationStreetAddress =
	import.meta.env.PUBLIC_ORGANIZATION_STREET || 'Strada Comunale Delle Corti, 61';
const organizationLocality =
	import.meta.env.PUBLIC_ORGANIZATION_CITY || 'Treviso';
const organizationCountry =
	import.meta.env.PUBLIC_ORGANIZATION_COUNTRY || 'IT';
const organizationAreaServed =
	import.meta.env.PUBLIC_ORGANIZATION_AREA_SERVED || 'IT';
const organizationSameAs = (import.meta.env.PUBLIC_ORGANIZATION_SAME_AS || '')
	.split(',')
	.map((entry) => entry.trim())
	.filter(Boolean);
const umamiScriptSrc = import.meta.env.PUBLIC_UMAMI_SCRIPT_SRC || 'https://umami.asoloweb.it/script.js';
const umamiWebsiteId =
	import.meta.env.PUBLIC_UMAMI_WEBSITE_ID || '517b6a8c-733f-4d9f-a924-17c001c2806d';
const cookieFirstSiteId =
	import.meta.env.PUBLIC_COOKIEFIRST_SITE_ID ||
	'controllocartellesattoriali.it-ab8997c4-07b9-4efd-ae2b-8e8a064a7ed1';

function resolveImageSrc(value: string) {
	if (!value) return '';
	if (value.startsWith('http://') || value.startsWith('https://') || value.startsWith('/')) {
		return value;
	}
	return `${DIRECTUS_URL}/assets/${value}`;
}

let logoLightSrc = import.meta.env.PUBLIC_LOGO_LIGHT || '/favicon.svg';

try {
	const optionsUrl = directusItemsUrl('options');
	optionsUrl.searchParams.set('fields', 'logo_light');
	const optionsResponse = await fetch(optionsUrl);
	if (optionsResponse.ok) {
		const optionsPayload = await optionsResponse.json();
		const options =
			optionsPayload?.data && Array.isArray(optionsPayload.data)
				? optionsPayload.data[0]
				: optionsPayload?.data;
		if (options?.logo_light) {
			logoLightSrc = resolveImageSrc(options.logo_light);
		}
	}
} catch (error) {
	console.error('Error fetching options for favicon:', error);
}

const absoluteLogoUrl = (() => {
	try {
		return new URL(logoLightSrc, siteUrl).toString();
	} catch {
		return logoLightSrc;
	}
})();

function getFaviconMimeType(src: string) {
	const cleanedSrc = src.split('?')[0].split('#')[0].toLowerCase();
	if (cleanedSrc.endsWith('.svg')) return 'image/svg+xml';
	if (cleanedSrc.endsWith('.png')) return 'image/png';
	if (cleanedSrc.endsWith('.webp')) return 'image/webp';
	if (cleanedSrc.endsWith('.jpg') || cleanedSrc.endsWith('.jpeg')) return 'image/jpeg';
	if (cleanedSrc.endsWith('.ico')) return 'image/x-icon';
	return undefined;
}

const faviconMimeType = getFaviconMimeType(logoLightSrc);

const organizationId = `${siteUrl}/#organization`;
const legalServiceId = `${siteUrl}/#legalservice`;
const organizationJsonLd = JSON.stringify(
	{
		'@context': 'https://schema.org',
		'@graph': [
			{
				'@type': 'Organization',
				'@id': organizationId,
				name: organizationName,
				url: siteUrl,
				logo: absoluteLogoUrl,
				email: organizationEmail,
				telephone: organizationPhone,
				sameAs: organizationSameAs,
			},
			{
				'@type': 'LegalService',
				'@id': legalServiceId,
				name: organizationName,
				url: siteUrl,
				image: absoluteLogoUrl,
				telephone: organizationPhone,
				email: organizationEmail,
				address: {
					'@type': 'PostalAddress',
					streetAddress: organizationStreetAddress,
					addressLocality: organizationLocality,
					addressCountry: organizationCountry,
				},
				areaServed: organizationAreaServed,
				provider: {
					'@id': organizationId,
				},
			},
		],
	},
	null,
	2
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type={faviconMimeType} href={logoLightSrc} />
		<link rel="shortcut icon" type={faviconMimeType} href={logoLightSrc} />
		<link rel="apple-touch-icon" href={logoLightSrc} />
		<meta name="viewport" content="width=device-width" />
		<meta name="theme-color" content="#000000" />
		<meta name="generator" content={Astro.generator} />
		<title>{resolvedTitle}</title>
		{seoDescription && <meta name="description" content={seoDescription} />}
		<script type="application/ld+json" set:html={organizationJsonLd}></script>
		<link rel="stylesheet" href="/vendor/aos.css" />
		<link rel="stylesheet" href="/vendor/swiper-bundle.min.css" />
		{shouldLoadThirdPartyScripts && (
			<>
				<script defer src={umamiScriptSrc} data-website-id={umamiWebsiteId}></script>
				<script src={`https://consent.cookiefirst.com/sites/${cookieFirstSiteId}/consent.js`}></script>
			</>
		)}
		<!-- Google tag (gtag.js) --> <script async src="https://www.googletagmanager.com/gtag/js?id=AW-10932709528"></script> <script> window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', 'AW-10932709528'); </script>

		<script type="text/javascript">
			(function(c,l,a,r,i,t,y){
				c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
				t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
				y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
			})(window, document, "clarity", "script", "vqwzxpkr6z");
		</script>
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
		<script defer src="/vendor/aos.js"></script>
		<script defer src="/scripts/aos-init.js"></script>
		<script defer src="/scripts/swiper-init.js"></script>
		<slot name="scripts" />
	</body>
</html>
