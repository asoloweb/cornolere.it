---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageContent from '../components/PageContent.astro';
import { directusItemsUrl } from '../lib/directus';

type Page = {
	status?: string;
	slug?: string;
	title?: string;
	Titolo?: string;
	seo_title?: string;
	seo_desc?: string;
	hide_page_header?: boolean;
	page_header?: string;
	editor?: unknown[];
};

async function fetchPageBySlug(slug: string) {
	const url = directusItemsUrl('pages');
	url.searchParams.set(
		'fields',
		'*,editor.item.*,editor.item.slider.*,editor.item.slider.slides.item.*,editor.item.card.single_card_id.*,editor.item.card.single_card_id.link.id,editor.item.card.single_card_id.link.slug,editor.item.card.single_card_id.link.title,editor.item.accordion.single_accordion_id.*'
	);
	url.searchParams.set('filter[status][_eq]', 'published');
	url.searchParams.set('filter[_or][0][slug][_eq]', slug);
	url.searchParams.set('filter[_or][1][slug][slug][_eq]', slug);
	const response = await fetch(url);
	const data = await response.json();
	return (data?.data?.[0] as Page | undefined) ?? null;
}

const routeSlug = String(Astro.params.slug || '').trim();
const page =
	(Astro.props?.page as Page | undefined) ||
	(routeSlug ? await fetchPageBySlug(routeSlug) : null);
---

<BaseLayout
	title={page?.title || page?.Titolo || 'Pagina'}
	seoTitle={page?.seo_title}
	seoDescription={page?.seo_desc}
>
	<PageContent page={page} />
</BaseLayout>
