---
import BaseLayout from '../layouts/BaseLayout.astro';
import { DIRECTUS_URL } from '../lib/directus';

const directusUrl =
	import.meta.env.PUBLIC_DIRECTUS_URL || import.meta.env.DIRECTUS_URL || DIRECTUS_URL;
---

<BaseLayout title="Area Riservata">
	<section class="area_wrapper">
		<div class="area_login" data-section="login">
			<h1>Area riservata</h1>
			<p>Accedi per vedere lo stato della tua pratica.</p>
			<form class="area_form" id="login-form">
				<label>
					<span>Email</span>
					<input name="email" type="email" autocomplete="email" required />
				</label>
				<label>
					<span>Password</span>
					<input name="password" type="password" autocomplete="current-password" required />
				</label>
				<button type="submit">Accedi</button>
				<p class="area_status" role="status" aria-live="polite"></p>
			</form>
		</div>

		<div class="area_dashboard" data-section="dashboard" hidden>
			<div class="area_header">
				<div>
					<h1>La tua pratica</h1>
					<p class="area_subtitle" id="pratica-status"></p>
				</div>
				<button class="area_logout" type="button" id="logout-btn">Esci</button>
			</div>

			<div class="area_card">
				<h2>Dati pratica</h2>
				<div class="area_pratica_selector" id="pratica-selector" hidden>
					<label>
						<span>Seleziona pratica</span>
						<select id="pratica-select"></select>
					</label>
				</div>
				<p><strong>ID pratica:</strong> <span id="pratica-id"></span></p>
				<p><strong>Stato:</strong> <span id="pratica-stato"></span></p>
			</div>

			<div class="area_card">
				<h2>Descrizione pratica</h2>
				<textarea id="pratica-descrizione" rows="6" placeholder="Descrivi la pratica..."></textarea>
			</div>

			<div class="area_card">
				<h2>Documenti</h2>
				<p class="area_hint">Carica PDF, JPG o PNG (max 15MB).</p>
				<input id="file-input" type="file" accept=".pdf,.jpg,.jpeg,.png" multiple />
				<ul class="file_list" id="file-list"></ul>
			</div>

			<div class="area_card">
				<h2>Invio pratica</h2>
				<label class="area_check">
					<input id="privacy-check" type="checkbox" required />
					<span>Accetto la <a href="/privacy-policy">privacy policy</a></span>
				</label>
				<label class="area_check">
					<input id="terms-check" type="checkbox" required />
					<span>Accetto le <a href="/termini-e-condizioni">condizioni d'uso</a></span>
				</label>
				<button class="area_submit" type="button" id="submit-pratica">Invia pratica</button>
				<p class="area_status" id="pratica-status-message" role="status" aria-live="polite"></p>
			</div>
		</div>
	</section>
</BaseLayout>

<script type="module" define:vars={{ directusUrl }} slot="scripts">
	const DIRECTUS_URL = directusUrl;
	const loginForm = document.getElementById('login-form');
	const loginSection = document.querySelector('[data-section="login"]');
	const dashboardSection = document.querySelector('[data-section="dashboard"]');
	const logoutBtn = document.getElementById('logout-btn');
	const praticaIdEl = document.getElementById('pratica-id');
	const praticaStatoEl = document.getElementById('pratica-stato');
	const praticaStatusEl = document.getElementById('pratica-status');
	const descrizioneEl = document.getElementById('pratica-descrizione');
	const fileInput = document.getElementById('file-input');
	const fileList = document.getElementById('file-list');
	const praticaSelector = document.getElementById('pratica-selector');
	const praticaSelect = document.getElementById('pratica-select');
	const privacyCheck = document.getElementById('privacy-check');
	const termsCheck = document.getElementById('terms-check');
	const submitPraticaBtn = document.getElementById('submit-pratica');
	const praticaStatusMessage = document.getElementById('pratica-status-message');

	let accessToken = localStorage.getItem('directus_access_token') || '';
	let pratiche = [];
	let pratica = null;
	let praticaLoaded = false;

	const apiFetch = (path, options = {}) => {
		const headers = Object.assign(
			{ Authorization: `Bearer ${accessToken}` },
			options.headers || {}
		);
		const requestOptions = Object.assign({}, options, { headers });
		return fetch(`${DIRECTUS_URL}${path}`, requestOptions);
	};

	const showStatus = (el, message, type) => {
		if (!el) return;
		el.textContent = message;
		el.dataset.state = type || '';
	};

	const setDashboardVisible = (visible) => {
		if (loginSection) loginSection.hidden = visible;
		if (dashboardSection) {
			dashboardSection.hidden = !visible;
			dashboardSection.classList.toggle('is-visible', !!visible);
		}
	};

	const loadPratica = async () => {
		if (!accessToken) return;
		praticaLoaded = false;
		const userRes = await apiFetch('/users/me');
		if (!userRes.ok) throw new Error('Auth error');
		const user = await userRes.json();
		const userId = user && user.data ? user.data.id : null;
		if (!userId) throw new Error('User not found');

		const fields =
			'fields=id,id_pratica,stato_pratica,descrizione,files.id,files.directus_files_id.id,files.directus_files_id.filename_download,files.directus_files_id.type,files.directus_files_id.filesize&sort=-date_created';
		const praticaRes = await apiFetch(`/items/pratiche?filter[cliente][_eq]=${userId}&${fields}`);
		if (!praticaRes.ok) throw new Error('Pratica non trovata');
		const praticaPayload = await praticaRes.json();
		pratiche = praticaPayload && praticaPayload.data ? praticaPayload.data : [];
		if (!pratiche.length) throw new Error('Pratica non trovata');

		const selectedId = pratica ? pratica.id : null;
		pratica =
			pratiche.find((item) => item.id === selectedId) ||
			pratiche[0] ||
			null;
		if (!pratica) throw new Error('Pratica non trovata');

		renderPraticheSelector(pratiche, pratica ? pratica.id : null);

		if (praticaIdEl) praticaIdEl.textContent = pratica.id_pratica || '-';
		if (praticaStatoEl) praticaStatoEl.textContent = pratica.stato_pratica || '-';
		if (praticaStatusEl)
			praticaStatusEl.textContent = `Stato: ${pratica.stato_pratica || '-'}`;
		if (descrizioneEl) descrizioneEl.value = pratica.descrizione || '';

		renderFiles(pratica.files || []);
		praticaLoaded = true;
	};

	const renderFiles = (files) => {
		if (!fileList) return;
		fileList.innerHTML = '';
		if (!files || !files.length) {
			const empty = document.createElement('li');
			empty.textContent = 'Nessun file caricato.';
			fileList.appendChild(empty);
			return;
		}
		files.forEach((fileRel) => {
			const file = fileRel && fileRel.directus_files_id ? fileRel.directus_files_id : null;
			if (!file) return;
			const item = document.createElement('li');
			item.innerHTML = `<span>${file.filename_download || 'file'}</span>`;
			const delBtn = document.createElement('button');
			delBtn.type = 'button';
			delBtn.textContent = 'Elimina';
			delBtn.addEventListener('click', () => deleteFile(fileRel.id, file.id));
			item.appendChild(delBtn);
			fileList.appendChild(item);
		});
	};

	const renderPraticheSelector = (items, selectedId) => {
		if (!praticaSelect || !praticaSelector) return;
		if (!items || items.length <= 1) {
			praticaSelector.hidden = true;
			return;
		}
		praticaSelector.hidden = false;
		praticaSelect.innerHTML = '';
		items.forEach((item) => {
			const option = document.createElement('option');
			option.value = item.id;
			option.textContent = item.id_pratica || `Pratica ${item.id}`;
			if (String(item.id) === String(selectedId)) option.selected = true;
			praticaSelect.appendChild(option);
		});
	};

	const uploadFiles = async (files) => {
		if (!pratica || !pratica.id || !files || !files.length) return;
		const maxSize = 15 * 1024 * 1024;
		const validFiles = Array.from(files).filter((file) => file.size <= maxSize);
		const invalidFiles = Array.from(files).filter((file) => file.size > maxSize);
		if (invalidFiles.length) {
			showStatus(
				praticaStatusMessage,
				`Alcuni file superano i 15MB e non sono stati caricati.`,
				'error'
			);
		}
		if (!validFiles.length) return;
		for (const file of validFiles) {
			const formData = new FormData();
			formData.append('file', file);
			const uploadRes = await apiFetch('/files', {
				method: 'POST',
				body: formData,
				headers: {},
			});
			if (!uploadRes.ok) continue;
			const uploadPayload = await uploadRes.json();
			const fileId = uploadPayload && uploadPayload.data ? uploadPayload.data.id : null;
			if (!fileId) continue;

			await apiFetch('/items/pratiche_files', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					pratiche_id: pratica.id,
					directus_files_id: fileId,
				}),
			});
		}
		await loadPratica();
	};

	const deleteFile = async (relationId, fileId) => {
		if (!relationId) return;
		await apiFetch(`/items/pratiche_files/${relationId}`, { method: 'DELETE' });
		if (fileId) {
			await apiFetch(`/files/${fileId}`, { method: 'DELETE' });
		}
		await loadPratica();
	};

	const submitPratica = async () => {
		if (!praticaLoaded || !pratica || !pratica.id) {
			showStatus(
				praticaStatusMessage,
				'Pratica non disponibile. Ricarica la pagina o accedi di nuovo.',
				'error'
			);
			return;
		}
		if (!privacyCheck || !privacyCheck.checked || !termsCheck || !termsCheck.checked) {
			showStatus(praticaStatusMessage, 'Devi accettare privacy e condizioni.', 'error');
			return;
		}
		try {
			const descrizione = descrizioneEl && descrizioneEl.value
				? descrizioneEl.value.trim()
				: '';
			const response = await apiFetch(`/items/pratiche/${pratica.id}`, {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					descrizione,
					stato_pratica: 'in_valutazione',
				}),
			});
			if (!response.ok) {
				showStatus(praticaStatusMessage, 'Errore durante il salvataggio.', 'error');
				return;
			}
			showStatus(praticaStatusMessage, 'Pratica inviata correttamente.', 'success');
			await loadPratica();
		} catch (error) {
			console.error('Errore invio pratica:', error);
			showStatus(praticaStatusMessage, 'Errore durante il salvataggio.', 'error');
		}
	};

	if (loginForm) {
		loginForm.addEventListener('submit', async (event) => {
			event.preventDefault();
			const formData = new FormData(loginForm);
			const email = String(formData.get('email') || '').trim();
			const password = String(formData.get('password') || '').trim();
			const statusEl = loginForm.querySelector('.area_status');

			showStatus(statusEl, 'Accesso in corso...', 'loading');
			const response = await fetch(`${DIRECTUS_URL}/auth/login`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ email, password }),
			});
			if (!response.ok) {
				showStatus(statusEl, 'Credenziali non valide.', 'error');
				return;
			}
			const payload = await response.json();
			const data = payload && payload.data ? payload.data : null;
			accessToken = data && data.access_token ? data.access_token : '';
			if (!accessToken) {
				showStatus(statusEl, 'Errore autenticazione.', 'error');
				return;
			}
			localStorage.setItem('directus_access_token', accessToken);
			if (data && data.refresh_token) {
				localStorage.setItem('directus_refresh_token', data.refresh_token);
			}

			showStatus(statusEl, '');
			setDashboardVisible(true);
			try {
				await loadPratica();
			} catch (error) {
				console.error('Errore caricamento pratica:', error);
				showStatus(
					praticaStatusMessage,
					'Impossibile caricare la pratica. Riprova più tardi.',
					'error'
				);
			}
		});
	}

	if (logoutBtn) {
		logoutBtn.addEventListener('click', () => {
			localStorage.removeItem('directus_access_token');
			localStorage.removeItem('directus_refresh_token');
			accessToken = '';
			setDashboardVisible(false);
		});
	}

	if (fileInput) {
		fileInput.addEventListener('change', async (event) => {
			const files = event.target.files;
			await uploadFiles(files);
			fileInput.value = '';
		});
	}

	if (praticaSelect) {
		praticaSelect.addEventListener('change', () => {
			const selectedId = praticaSelect.value;
			pratica = pratiche.find((item) => String(item.id) === String(selectedId)) || pratica;
			if (!pratica) return;
			if (praticaIdEl) praticaIdEl.textContent = pratica.id_pratica || '-';
			if (praticaStatoEl) praticaStatoEl.textContent = pratica.stato_pratica || '-';
			if (praticaStatusEl)
				praticaStatusEl.textContent = `Stato: ${pratica.stato_pratica || '-'}`;
			if (descrizioneEl) descrizioneEl.value = pratica.descrizione || '';
			renderFiles(pratica.files || []);
		});
	}

	if (submitPraticaBtn) {
		submitPraticaBtn.addEventListener('click', submitPratica);
	}

	if (accessToken) {
		setDashboardVisible(false);
		loadPratica()
			.then(() => {
				setDashboardVisible(true);
			})
			.catch((error) => {
				console.error('Errore caricamento pratica:', error);
				setDashboardVisible(false);
			});
	}
</script>

<style>
	.area_wrapper {
		max-width: var(--max-width);
		margin: 40px auto 80px;
		padding: 0 20px;
		display: grid;
		gap: 24px;
	}

	.area_login,
	.area_dashboard {
		background: var(--grigio-chiaro);
		border-radius: 24px;
		padding: 32px;
	}

	.area_form {
		display: grid;
		gap: 14px;
		max-width: 420px;
	}

	.area_form label {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.area_pratica_selector label {
		display: flex;
		flex-direction: column;
		gap: 6px;
		max-width: 320px;
		margin-bottom: 12px;
	}

	.area_pratica_selector select {
		border: 1px solid #d9d9d9;
		border-radius: 12px;
		padding: 10px 12px;
		font: inherit;
		background: #fff;
	}

	.area_form input,
	.area_form textarea,
	.area_card textarea {
		border: 1px solid #d9d9d9;
		border-radius: 12px;
		padding: 12px 14px;
		font: inherit;
	}

	.area_form button,
	.area_submit,
	.area_logout {
		border: 0;
		border-radius: 999px;
		padding: 12px 18px;
		background: var(--primary);
		color: var(--bianco);
		font-family: var(--font-heading);
		cursor: pointer;
	}

	.area_dashboard {
		display: none;
		gap: 20px;
	}

	.area_dashboard.is-visible {
		display: grid;
	}

	.area_header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 16px;
		flex-wrap: wrap;
	}

	.area_card {
		background: var(--bianco);
		border-radius: 20px;
		padding: 20px;
	}

	.file_list {
		list-style: none;
		padding: 0;
		margin: 16px 0 0;
		display: grid;
		gap: 10px;
	}

	.file_list li {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 12px;
		background: #fff;
		border-radius: 12px;
		padding: 10px 12px;
	}

	.file_list button {
		border: 0;
		background: #ef4444;
		color: #fff;
		border-radius: 999px;
		padding: 6px 12px;
		cursor: pointer;
	}

	.area_check {
		display: flex;
		gap: 10px;
		align-items: center;
		margin-bottom: 10px;
	}

	.area_status {
		font-size: 14px;
		min-height: 20px;
	}
</style>
