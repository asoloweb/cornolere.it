---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageContent from '../components/PageContent.astro';
import PartecipaForm from '../components/PartecipaForm.astro';
import GoogleReviewsBlock from '../components/google_reviews_block.astro';
import HeroBlock from '../components/hero_block.astro';
import { DIRECTUS_URL, directusItemsUrl } from '../lib/directus';

type Page = {
	status?: string;
	slug?: string;
	title?: string;
	Titolo?: string;
	seo_title?: string;
	seo_desc?: string;
	description?: string;
	hide_page_header?: boolean;
	page_header?: string;
	featured_image?: string;
	editor?: unknown[];
};

type HeroBlockItem = {
	id?: number;
	titolo?: string;
	sottotitolo?: string;
	paragrafo?: string;
	label?: string;
	href?: string;
	immagine?: string;
	inverti?: boolean;
	background_color?: string;
};

async function fetchPartecipaPage() {
	const url = directusItemsUrl('pages');
	url.searchParams.set(
		'fields',
		'*,slug.*,editor.item.*,editor.item.slider.*,editor.item.slider.slides.item.*,editor.item.card.single_card_id.*,editor.item.card.single_card_id.link.id,editor.item.card.single_card_id.link.slug,editor.item.card.single_card_id.link.title,editor.item.accordion.single_accordion_id.*'
	);
	url.searchParams.set('filter[status][_eq]', 'published');
	url.searchParams.set('filter[slug][_eq]', 'partecipa');

	const response = await fetch(url);
	const data = await response.json();
	return (data?.data?.[0] as Page | undefined) ?? null;
}

const page: Page | null = await fetchPartecipaPage();
const pageTitle = page?.title || page?.Titolo || '';
const pageDescription = page?.description || '';

const homeHero14: HeroBlockItem = {
	id: 14,
	titolo: 'Analisi professionale della tua <span>cartella esattoriale</span>',
	sottotitolo:
		"Con una quota di 99€, entro 2 giorni lavorativi riceverai nella tua area riservata l'esito dell'analisi in PDF, certificato dallo Studio Legale, con la verifica di correttezza della cartella e indicazioni chiare su come procedere.",
	paragrafo: '',
	label: 'Partecipa >',
	href: '/partecipa',
	immagine: '9e4fa297-2d00-44be-862d-db3071894391',
	inverti: false,
	background_color: '',
};

function resolveImageSrc(value: string) {
	if (!value) return '';
	if (value.startsWith('http://') || value.startsWith('https://') || value.startsWith('/')) {
		return value;
	}
	return `${DIRECTUS_URL}/assets/${value}`;
}

const pageHeaderImage = page?.featured_image ? resolveImageSrc(page.featured_image) : '';
const showPageHeader = page ? !page.hide_page_header : false;
---

<BaseLayout
	title={page?.title || page?.Titolo || 'Partecipa'}
	seoTitle={page?.seo_title}
	seoDescription={page?.seo_desc}
>
	{page && (
		<div class="partecipa_preheader">
			<div class="partecipa_preheader_inner">
				<section id="block-hero-block-14-2" class="editor_block editor_block_hero_block">
					<HeroBlock
						item={String(homeHero14.id ?? '14')}
						titolo={homeHero14.titolo}
						sottotitolo={homeHero14.sottotitolo}
						paragrafo={homeHero14.paragrafo}
						label={homeHero14.label}
						href={homeHero14.href}
						immagine={homeHero14.immagine}
						inverti={homeHero14.inverti}
						background_color={homeHero14.background_color}
					/>
				</section>
				<div class="partecipa_preheader_form">
					<PartecipaForm title="Controlla la tua cartella con un supporto legale qualificato a soli 99€" />
				</div>
			</div>
		</div>
	)}
	<GoogleReviewsBlock
		titolo="Cosa dicono i clienti"
		sottotitolo="Recensioni Google di Studio Legale Portantiolo & Partners"
		google_business_query="Studio Legale Portantiolo & Partners"
		numero_recensioni={6}
	/>

	{showPageHeader && (
		<div
			class="page_header"
			style={pageHeaderImage ? `background-image: url('${pageHeaderImage}')` : undefined}
		>
			<div class="page_header_inner">
				{pageTitle && <h1 data-aos="fade-up" data-aos-duration="1500">{pageTitle}</h1>}
				{pageDescription && <p data-aos="fade-up" data-aos-duration="1800">{pageDescription}</p>}
			</div>
		</div>
	)}

	<PageContent
		page={page}
		showHeader={false}
		notFoundTitle="Pagina partecipa non trovata"
		notFoundMessage="La pagina partecipa richiesta non esiste."
	/>
</BaseLayout>

<style>
	.partecipa_preheader {
		background: var(--grigio-chiaro);
	}

	.partecipa_preheader_inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 20px;
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
		gap: 28px;
		align-items: start;
	}

	#block-hero-block-14-2 {
		min-width: 0;
	}



	#block-hero-block-14-2 :global(.hero_block) {
		margin: 0;
		max-width: 100%;
		flex-direction: column-reverse;
	}

	#block-hero-block-14-2 :global(.hero_button) {
		display: none !important;
	}

	.partecipa_preheader_form {
		min-width: 0;
	}

	.partecipa_preheader_form :global(.contact_form) {
		position: relative;
		margin-top: 22px;
	}

	.partecipa_preheader_form :global(.contact_form)::before {
		content: 'Promozione valida fino al 31/03';
		position: absolute;
		top: -14px;
		left: 20px;
		background: var(--primary);
		color: #fff;
		font-family: var(--font-heading);
		font-size: 18px;
		letter-spacing: 0.03em;
		padding: 6px 14px;
		border-radius: 999px;
		line-height: 1;
		z-index: 2;
	}

	@media (max-width: 980px) {
		.partecipa_preheader_inner {
			grid-template-columns: 1fr;
		}

	}
</style>
